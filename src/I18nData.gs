function normalizeClientLang_(lang) {
  return String(lang || '').toLowerCase() === 'pl' ? 'pl' : 'en';
}

function getDefaultClientLang_() {
  const locale = String(Session.getActiveUserLocale() || '').toLowerCase();
  return locale.indexOf('pl') === 0 ? 'pl' : 'en';
}

function getClientTranslations(lang) {
  const normalized = normalizeClientLang_(lang || getDefaultClientLang_());
  return runTimed_('getClientTranslations', () => {
    return CLIENT_I18N_PACKS[normalized] || CLIENT_I18N_PACKS.en;
  }, `lang:${normalized}`);
}
